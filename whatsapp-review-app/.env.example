PORT=4000
PUBLIC_APP_URL=http://localhost:4000
DATABASE_PATH=./data/lume-reviews.db
ADMIN_API_KEY=change-this-long-secret

# Use mock for testing, cloud for real WhatsApp sending
WHATSAPP_MODE=mock
META_GRAPH_VERSION=v23.0
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=choose-a-random-token
META_TEMPLATE_NAME=lume_experience_request
META_TEMPLATE_LANGUAGE=fr

GOOGLE_REVIEW_URL=https://search.google.com/local/writereview?placeid=YOUR_PLACE_ID
SEND_BATCH_SIZE=10
